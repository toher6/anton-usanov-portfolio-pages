---
import '../styles/global.css';
import { SITE } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const { title = SITE.title, description = SITE.description } = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <script is:inline>
      // Ставим сохранённый язык до первой отрисовки, чтобы избежать мигания RU → EN
      try {
        var lang = localStorage.getItem('lang') || 'ru';
        document.documentElement.dataset.lang = lang;
      } catch (e) {}
    </script>
  </head>
  <body>
    <div class="page-container">
      <slot />
    </div>
    <script src="../scripts/scramble.ts"></script>
    <script src="../scripts/copy-button.ts"></script>
  </body>
</html>

<style>
  .page-container {
    max-width: 1440px;
    margin-inline: auto;
    padding-inline: var(--page-padding-inline);
  }
</style>
