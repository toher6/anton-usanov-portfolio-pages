---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/Button.astro';

const title = 'Страница не найдена';
const description = 'Такой страницы не существует';
---

<BaseLayout title={title} description={description}>
  <div class="not-found">
    <p class="text-pretitle" data-i18n-scope>404</p>
    <p class="text-h1" data-i18n-scope>Страница не найдена</p>
    <p class="text-body subtitle" data-i18n-scope>Похоже, такой страницы не существует или она была перемещена</p>
    <Button variant="primary" href="/">На главную</Button>
  </div>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 12px;
    padding-block: 160px;
  }

  .subtitle {
    color: var(--color-zinc-dust);
    margin-bottom: 16px;
  }
</style>
