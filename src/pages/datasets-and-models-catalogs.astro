---
import CaseLayout from '../layouts/CaseLayout.astro';
import CaseHero from '../components/CaseHero.astro';
import CaseSection from '../components/CaseSection.astro';
import ImageBlock from '../components/ImageBlock.astro';
import Gallery from '../components/Gallery.astro';
import ResearchPanel from '../components/ResearchPanel.astro';
import ResultCard from '../components/ResultCard.astro';
import companyLogo from '../assets/images/logos/sber-logo.svg';
import coverImage from '../assets/images/cases/datasets-and-models-catalogs/cover.png';
import competitorAnalysis1 from '../assets/images/cases/datasets-and-models-catalogs/competitor-analysis-1.png';
import competitorAnalysis2 from '../assets/images/cases/datasets-and-models-catalogs/competitor-analysis-2.png';
import catalogsScreen1 from '../assets/images/cases/datasets-and-models-catalogs/catalogs-screens-1.png';
import catalogsScreen2 from '../assets/images/cases/datasets-and-models-catalogs/catalogs-screens-2.png';
import detailPageScreens from '../assets/images/cases/datasets-and-models-catalogs/detail-page-screens.png';

const title = 'Спроектировал разделы публикации датасетов и моделей';
const description =
  'За месяц спроектировал каталоги моделей и датасетов — инструменты публикации для внутренних и внешних Data Science и ML-специалистов. Провёл конкурентный анализ сервисов и интервью со специалистами, чтобы понять критерии поиска и приоритеты в фильтрации';

const meta = [
  { label: 'Роль', value: 'Продуктовый дизайнер' },
  { label: 'Платформа', value: 'Desktop, tablet, mobile' },
  { label: 'Год', value: '2025' },
];

const results = [
  { value: '500 - 1000', label: 'Активных пользователей в месяц' },
  { value: '50 - 150', label: 'Опубликованных датасетов' },
  { value: '30 - 80', label: 'Опубликованных моделей' },
];

const interviewSpecs = [
  { label: 'Тип исследования', value: 'Экспресс-интервью' },
  { label: 'Формат', value: 'Онлайн-встречи на 30 минут' },
  { label: 'Респонденты', value: 'Data Science специалисты Сбера' },
  { label: 'Количество', value: '5 человек' },
];

const insights = [
  {
    number: '#1',
    text: 'Пользователи ищут датасеты и модели как через поисковик, так и на специализированных сервисах',
  },
  {
    number: '#2',
    text: 'При поиске датасетов обращают внимание на количество файлов и количество строк в нем. Самые часто-используемые фильтры: тип данных, решаемая задача, наличие разметки',
  },
  {
    number: '#3',
    text: 'При поиске моделей обращают внимание на тип решаемой задачи, могут отфильтровать по фреймворку',
  },
];
---

<CaseLayout title="Anton Usanov — Datasets and models catalogs for Platform AI" description={description}>
  <div class="case">
    <CaseHero
      title={title}
      companyLogo={companyLogo}
      companyName="Платформы AI"
      description={description}
      meta={meta}
      results={results}
      coverImage={coverImage}
    />

    <CaseSection
      preTitle="Контекст и задача"
      title="Каталоги моделей и датасетов на Платформе AI — инструмент публикации для внутренних и внешних ML-специалистов"
    >
      Нужен был инструмент, который позволит специалистам находить нужные данные и модели по релевантным критериям, а
      владельцам — публиковать их с гибкими настройками доступа (публично или ограниченному кругу) и с заделом под
      будущую монетизацию
    </CaseSection>

    <div class="case-block">
      <CaseSection
        preTitle="Конкурентный анализ"
        title="На рынке уже существовали похожие решения, поэтому начал с анализа аналогов"
      >
        Разобрал концепции, особенности способы монетизации и UI-паттерны Hugging Face, Kaggle, OpenML, data.world,
        Amazon Data Marketplace, Google Dataset Search
      </CaseSection>
      <Gallery images={[competitorAnalysis2, competitorAnalysis1]} />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Интервью" title="Провёл 5 интервью с ML и DS-специалистами, чтобы понять, как они на самом деле ищут модели и датасеты" />
      <div class="spec-grid">
        <ResearchPanel tag="Методология" tagColor="var(--color-sky)">
          {interviewSpecs.map((item) => (
            <div class="spec-row">
              <p class="text-body spec-label" data-i18n-scope>{item.label}</p>
              <p class="text-label" data-i18n-scope>{item.value}</p>
            </div>
          ))}
        </ResearchPanel>
        <ResearchPanel tag="Ключевые инсайты" tagColor="var(--color-mint)" rowGap={24}>
          {insights.map((item) => (
            <div class="insight-row">
              <p class="text-body insight-number" data-i18n-scope>{item.number}</p>
              <p class="text-label insight-text" data-i18n-scope>{item.text}</p>
            </div>
          ))}
        </ResearchPanel>
      </div>
    </div>

    <div class="case-block">
      <CaseSection
        preTitle="Финальное дизайн-решение"
        title="На основе инсайтов из интервью и конкурентного анализа спроектировал ключевые разделы"
      >
        Отрисовал каталоги моделей и датасетов с фильтрами, страницы моделей и датасетов с описаниями, разделы для
        публикации на Платформе. UI построен на компонентах дизайн-системы "Малахит"
      </CaseSection>

      <Gallery images={[catalogsScreen1, catalogsScreen2]} caption="Каталоги датасетов и моделей с карточками и фильтрацией" />
      <ImageBlock image={detailPageScreens} framed={false} caption="Страницы датасета и модели" />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Результат" title="Спроектировал каталоги моделей и датасетов для Платформы AI">
        Каталоги и страницы датасетов и моделей рассчитаны на сценарии внутренних и внешних ML/DS-специалистов. Будучи
        единственным дизайнером на разделе, провёл весь цикл самостоятельно за месяц — от конкурентного анализа и
        интервью до финальных макетов
      </CaseSection>
      <div class="results-items">
        {results.map((item) => (
          <ResultCard value={item.value} label={item.label} />
        ))}
      </div>
    </div>
  </div>
</CaseLayout>

<style>
  .case {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 100px;
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .case-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 44px;
    width: 100%;
  }

  .spec-grid {
    display: flex;
    align-items: stretch;
    gap: 32px;
    width: 100%;
  }

  .results-items {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }

  .spec-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    width: 100%;
  }

  .spec-label {
    color: var(--color-zinc-dust);
  }

  .insight-row {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    width: 100%;
  }

  .insight-number {
    flex-shrink: 0;
    width: 36px;
    color: var(--color-zinc-dust);
  }

  .insight-text {
    flex: 1 0 0;
    min-width: 0;
  }
</style>
