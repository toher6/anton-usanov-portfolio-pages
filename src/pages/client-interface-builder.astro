---
import CaseLayout from '../layouts/CaseLayout.astro';
import CaseHero from '../components/CaseHero.astro';
import CaseSection from '../components/CaseSection.astro';
import ImageBlock from '../components/ImageBlock.astro';
import Gallery from '../components/Gallery.astro';

import sberLogo from '../assets/images/logos/sber-logo.svg';
import coverImage from '../assets/images/cases/client-interface-builder/cover.png';
import templateCatalog from '../assets/images/cases/client-interface-builder/template-catalog.png';
import sketch from '../assets/images/cases/client-interface-builder/sketch.png';
import competitor1 from '../assets/images/cases/client-interface-builder/competitor-1.png';
import competitor2 from '../assets/images/cases/client-interface-builder/competitor-2.png';
import competitor3 from '../assets/images/cases/client-interface-builder/competitor-3.png';
import specScreenshot from '../assets/images/cases/client-interface-builder/spec-screenshot.png';
import survey1 from '../assets/images/cases/client-interface-builder/survey-1.png';
import survey2 from '../assets/images/cases/client-interface-builder/survey-2.png';
import survey3 from '../assets/images/cases/client-interface-builder/survey-3.png';
import survey4 from '../assets/images/cases/client-interface-builder/survey-4.png';
import survey5 from '../assets/images/cases/client-interface-builder/survey-5.png';
import survey6 from '../assets/images/cases/client-interface-builder/survey-6.png';
import survey7 from '../assets/images/cases/client-interface-builder/survey-7.png';
import mainScreen from '../assets/images/cases/client-interface-builder/main-screen.png';
import blocks1 from '../assets/images/cases/client-interface-builder/blocks-1.png';
import blocks2 from '../assets/images/cases/client-interface-builder/blocks-2.png';
import blocks3 from '../assets/images/cases/client-interface-builder/blocks-3.png';
import blocks4 from '../assets/images/cases/client-interface-builder/blocks-4.png';
import blocks5 from '../assets/images/cases/client-interface-builder/blocks-5.png';
import blocks6 from '../assets/images/cases/client-interface-builder/blocks-6.png';
import previewMode from '../assets/images/cases/client-interface-builder/preview-mode.png';
import resultMockups from '../assets/images/cases/client-interface-builder/result-mockups.png';

const meta = [
  { label: 'Роль', value: 'Продуктовый дизайнер' },
  { label: 'Платформа', value: 'Desktop' },
  { label: 'Год', value: '2024 - 2025' },
];

const results = [
  { value: '0 → 1', label: 'Спроектировал раздел с нуля' },
  { value: '2', label: 'Раунда юзабилити-тестирования' },
  { value: '118', label: 'Экранов отрисовано' },
];

const researchInsights = [
  {
    number: '#1',
    text: 'Шаблоны-заготовки для статусной модели не дают пользователям понимания механик и принципов дальнейшего взаимодействия',
  },
  {
    number: '#2',
    text: 'У пользователей есть потребность видеть созданные статусы покупки не совершая дополнительных действий',
  },
  {
    number: '#3',
    text: 'Непонятна категоризация, названия и назначение блоков, из которых строится клиентский интерфейс',
  },
];
---

<CaseLayout
  title="Anton Usanov — Client interface builder for Platform AI"
  description="За 2 месяца спроектировал гибкий конструктор клиентского интерфейса. Провёл 2 раунда юзабилити-тестирования и совместно с аналитиками продумал логику настройки готовых блоков под задачи публикуемых в каталоге продуктов"
>
  <div class="case-content">
    <CaseHero
      title="С нуля спроектировал конструктор клиентского интерфейса"
      companyLogo={sberLogo}
      companyName="Платформы AI"
      description="За 2 месяца спроектировал гибкий конструктор клиентского интерфейса. Провёл 2 раунда юзабилити-тестирования и совместно с аналитиками продумал логику настройки готовых блоков под задачи публикуемых в каталоге продуктов"
      meta={meta}
      results={results}
      coverImage={coverImage}
    />

    <CaseSection preTitle="О проекте" title="Платформа AI — маркетплейс ИИ-решений для бизнеса">
      В каталоге партнеры Сбера публиковали свои продукты, каждый из которых нуждался в клиентском интерфейсе — экраном, с которым пользователь взаимодействует после покупки
    </CaseSection>

    <div class="case-block">
      <CaseSection preTitle="Контекст" title="Создание клиентского интерфейса — один из этапов публикации продукта">
        Набор из пяти готовых сценариев с фиксированной логикой не покрывал разнообразие продуктов, которые публиковались на Платформе
      </CaseSection>
      <ImageBlock image={templateCatalog} caption="5 шаблонов клиентского интерфейса" />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Задача" title="Спроектировать гибкий, интуитивный инструмент для владельцев ИИ-продуктов">
        Кастомная разработка интерфейсов под каждый продукт требовала огромных ресурсов, а загрузка чужого кода на платформу создавала риски безопасности. С командой аналитики пришли к выводу, что решение — конструктор с готовыми блоками
      </CaseSection>
      <ImageBlock image={sketch} caption="Скетч аналитиков на старте" framed={false} />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Дискавери" title="Изучил смежные решения, так как прямых аналогов не было">
        <p>Я проанализировал интерфейсы конструкторов бизнес-процессов и сценариев, low-code платформы с визуальной сборкой, конструкторы чат-ботов</p>
        <p>Параллельно мы с аналитиками и владельцем продукта брейнштормили сценарии использования конструктора, пользовательский путь, варианты отображения этапов создания ИИ-приложения и нейминг блоков конструктора</p>
      </CaseSection>
      <Gallery images={[competitor1, competitor2, competitor3]} caption="Скриншоты аналогов" />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Первый прототип" title="Провел юзабилити-тестирование с 5 владельцами продуктов" />
      <div class="spec-grid">
        <div class="spec-panel">
          <div class="spec-row">
            <p class="text-body spec-label" data-i18n-scope>Тип исследования</p>
            <p class="text-label spec-value" data-i18n-scope>Юзабилити-тестирование</p>
          </div>
          <div class="spec-row">
            <p class="text-body spec-label" data-i18n-scope>Формат</p>
            <p class="text-label spec-value" data-i18n-scope>Очное модерируемое</p>
          </div>
          <div class="spec-row">
            <p class="text-body spec-label" data-i18n-scope>Респонденты</p>
            <p class="text-label spec-value" data-i18n-scope>Владельцы продуктов на Платформе</p>
          </div>
          <div class="spec-row">
            <p class="text-body spec-label" data-i18n-scope>Количество</p>
            <p class="text-label spec-value" data-i18n-scope>5 человек</p>
          </div>
        </div>
        <div class="spec-panel">
          <p class="text-body spec-label" data-i18n-scope>Ключевые инсайты</p>
          {researchInsights.map((insight) => (
            <div class="insight-row">
              <p class="text-body insight-number">{insight.number}</p>
              <p class="text-label insight-text" data-i18n-scope>{insight.text}</p>
            </div>
          ))}
        </div>
      </div>
      <ImageBlock image={specScreenshot} framed={false} />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Новая итерация и финальное дизайн-решение" title="На основе фидбэка и референсов собрал новый прототип и провел 2 раунд тестирования. Критических проблем не выявил">
        Комментарии касались в основном текстов, которые доработал во время сборки финальных макетов
      </CaseSection>
      <Gallery
        images={[survey1, survey2, survey3, survey4, survey5, survey6, survey7]}
        caption="Предварительный опрос, на основе которого формируются статусы публикуемого продукта"
      />
      <ImageBlock image={mainScreen} caption="Главный экран конструктора со статусной сеткой и карточками с наполнением статусов" />
      <Gallery images={[blocks1, blocks2, blocks3, blocks4, blocks5, blocks6]} caption="Каталог блоков и примеры их настройки" />
      <ImageBlock image={previewMode} caption="Режим предпросмотра настроенного интерфейса" />
    </div>

    <div class="case-block">
      <CaseSection preTitle="Результат" title="Спроектировал и протестировал гибкий инструмент для создания клиентских интерфейсов на базе Платформы AI">
        Конструктор рассчитан на потребности продуктов, которые публиковались в каталоге. Будучи единственным дизайнером на проекте, провёл весь цикл самостоятельно за 2 месяца — от исследования аналогов до финальных макетов
      </CaseSection>
      <ImageBlock image={resultMockups} caption="Отрисованные макеты" framed={false} />
    </div>
  </div>
</CaseLayout>

<style>
  .case-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 88px;
    width: 100%;
    padding-block: 24px 96px;
  }

  .case-block {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 44px;
    width: 100%;
  }

  .spec-grid {
    display: flex;
    align-items: stretch;
    gap: 32px;
    width: 100%;
  }

  .spec-panel {
    display: flex;
    flex: 1 0 0;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    padding: 36px;
    border-radius: var(--radius-2xl);
    background: var(--color-black-3);
  }

  .spec-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    width: 100%;
  }

  .spec-label {
    color: var(--color-zinc-dust);
  }

  .spec-value {
    color: var(--color-black);
  }

  .insight-row {
    display: flex;
    align-items: flex-start;
    gap: 32px;
    width: 100%;
  }

  .insight-number {
    flex-shrink: 0;
    width: 36px;
    color: var(--color-zinc-dust);
  }

  .insight-text {
    flex: 1 0 0;
    color: var(--color-black);
  }
</style>
