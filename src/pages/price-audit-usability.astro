---
import CaseLayout from '../layouts/CaseLayout.astro';
import CaseHero from '../components/CaseHero.astro';
import CaseSection from '../components/CaseSection.astro';
import ImageBlock from '../components/ImageBlock.astro';
import BeforeAfterSlider from '../components/BeforeAfterSlider.astro';
import StatusCard from '../components/StatusCard.astro';
import ResultCard from '../components/ResultCard.astro';
import sberLogo from '../assets/images/logos/sber-logo.svg';
import prototypeFlow from '../assets/images/cases/price-audit-usability/prototype-flow.png';
import improvementsTable from '../assets/images/cases/price-audit-usability/improvements-table.png';
import recognitionErrorBefore from '../assets/images/cases/price-audit-usability/recognition-error-before.png';
import recognitionErrorAfter from '../assets/images/cases/price-audit-usability/recognition-error-after.png';
import resultsTableBefore from '../assets/images/cases/price-audit-usability/results-table-before.png';
import resultsTableAfter from '../assets/images/cases/price-audit-usability/results-table-after.png';

const meta = [
  { label: 'Роль', value: 'Продуктовый дизайнер' },
  { label: 'Год', value: '2026' },
];

const results = [
  { value: '6', label: 'Участников тестирования' },
  { value: '2 из 3', label: 'Гипотезы подтверждены' },
  { value: '12', label: 'Проблем выявлено' },
];

const hypotheses = [
  { status: 'confirmed', text: 'Пользователям сложно понять логику интерфейса без инструкции' },
  { status: 'confirmed', text: 'Пользователям сложно интерпретировать результаты аудита спецификации' },
  { status: 'rejected', text: 'Пользователям недостаточно данных для принятия решений в рамках сценария аудита спецификации' },
] as const;
---

<CaseLayout
  title="Anton Usanov — Usability test for Price Audit"
  description="Инициировал тестирование прототипа с 6 сотрудниками блока «Строительство», подтвердил 2 из 3 гипотез и приоритизировал 12 найденных проблем"
>
  <div class="case">
    <CaseHero
      title="Провел юзабилити-тестирование"
      companyLogo={sberLogo}
      companyName="Аудита цен"
      description="Инициировал тестирование прототипа с 6 сотрудниками блока «Строительство», подтвердил 2 из 3 гипотез и приоритизировал 12 найденных проблем. Скорректированные макеты получили положительную реакцию и от заказчика, и от пользователей на согласовании"
      meta={meta}
      results={results}
    />

    <CaseSection
      preTitle="Контекст и задача"
      title="Аудит цен — сервис, который помогает проверять закупочные цены на соответствие рынку"
    >
      Он разрабатывался почти год, и за это время требования к интерфейсу и сценарии использования несколько раз
      менялись. Команда постоянно была на связи с заказчиком, но обратная связь от конечных пользователей оставалась
      негативной. Нужно было понять, закрывает ли новая версия сервиса реальные потребности пользователей в сценарии
      аудита спецификации, и что мешает работать с интерфейсом самостоятельно
    </CaseSection>

    <section class="section-group">
      <CaseSection preTitle="Процесс" title="Я инициировал проведение юзабилити-тестирования и провёл 6 очных модерируемых сессий с элементами интервью">
        <p>Респондентами выступили сотрудники блока «Строительство», которые участвуют в оценке спецификаций и определении стоимости закупки</p>
        <p>Цель исследования — понять, закрывает ли новая версия сервиса потребности пользователей в сценарии аудита спецификации, и что мешает работать с интерфейсом самостоятельно. Результат должен был помочь команде принять решение о доработке функционала</p>
      </CaseSection>

      <ImageBlock image={prototypeFlow} framed={false} />
    </section>

    <section class="section-group">
      <CaseSection preTitle="Инсайты" title="2 из 3 гипотез подтвердились">
        По итогам тестирования узнал различные инсайты, выявил и приоритизировал 12 проблем разной критичности — 6 из
        них в высоком приоритете
      </CaseSection>

      <div class="hypotheses">
        {hypotheses.map((h) => (
          <StatusCard status={h.status}>{h.text}</StatusCard>
        ))}
      </div>

      <ImageBlock image={improvementsTable} />
    </section>

    <section class="section-group">
      <CaseSection
        preTitle="Доработка"
        title="Согласовал список доработок с командой и заказчиком, скорректировал макеты"
      >
        Сделал ошибки заметнее, переписал формулировки результатов, дал более чёткие подсказки по интерфейсу
      </CaseSection>

      <BeforeAfterSlider
        before={recognitionErrorBefore}
        after={recognitionErrorAfter}
        beforeLabel="Старый вариант"
        afterLabel="Новый вариант"
        caption="Состояние ошибки распознавания в блоке заполнения запроса — до и после юзабилити-тестирования"
      />

      <BeforeAfterSlider
        before={resultsTableBefore}
        after={resultsTableAfter}
        beforeLabel="Старый вариант"
        afterLabel="Новый вариант"
        caption="Блок результатов аудита спецификации — до и после юзабилити-тестирования"
      />
    </section>

    <div class="section-group">
      <CaseSection
        preTitle="Результат"
        title="Провёл 6 модерируемых сессий, подтвердил 2 из 3 гипотез, приоритизировал 12 проблем"
      >
        При демонстрации результатов на созвоне с заказчиком и стейкхолдерами прозвучала прямая положительная оценка
        проделанной работы, а сотрудники блока «Строительство» позитивно отреагировали на изменения при финальном
        согласовании
      </CaseSection>

      <div class="results-items">
        {results.map((item) => (
          <ResultCard value={item.value} label={item.label} />
        ))}
      </div>
    </div>
  </div>
</CaseLayout>

<style>
  .case {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 100px;
    width: 100%;
    padding-bottom: 96px;
  }

  .section-group {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 44px;
    width: 100%;
  }

  .hypotheses {
    display: flex;
    align-items: stretch;
    gap: 24px;
    width: 100%;
  }

  .results-items {
    display: flex;
    align-items: center;
    gap: 20px;
    flex-wrap: wrap;
  }
</style>
