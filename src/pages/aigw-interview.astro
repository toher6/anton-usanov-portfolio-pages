---
import CaseLayout from '../layouts/CaseLayout.astro';
import CaseHero from '../components/CaseHero.astro';
import CaseSection from '../components/CaseSection.astro';
import ImageBlock from '../components/ImageBlock.astro';
import StatusCard from '../components/StatusCard.astro';
import sberLogo from '../assets/images/logos/sber-logo.svg';
import interviewQuestions from '../assets/images/cases/aigw-interview/interview-questions.png';
import resultSummary from '../assets/images/cases/aigw-interview/result-summary.png';

const title = 'Провел серию интервью';
const description =
  'Провёл исследование для сервиса для внутренних разработчиков ИИ-агентов. Подготовил гайд и провёл 8 глубинных интервью с командами, которые проходят процесс вывода ИИ-агента в продакшн. Подтвердил 3 из 4 гипотез и сформировал рекомендации на основе инсайтов';

const hypotheses = [
  { status: 'confirmed', text: 'Разработчики не до конца понимают структуру и требования, описанные в текущей документации' },
  { status: 'confirmed', text: 'При возникновении трудностей разработчики чаще прибегают к помощи коллег, чем к документации' },
  { status: 'confirmed', text: 'Разработчикам не хватает единого интерфейса для контроля прогресса агента' },
  { status: 'rejected', text: 'Разработчики не понимают, на каком этапе находится их агент (отправлен, проверен, принят и т.д.)' },
] as const;
---

<CaseLayout title="Anton Usanov — Interview for AIGW" description={description}>
  <div class="page">
    <CaseHero
      title={title}
      companyLogo={sberLogo}
      companyName="AI Gateway"
      description={description}
      meta={[
        { label: 'Роль', value: 'Продуктовый дизайнер' },
        { label: 'Год', value: '2025' },
      ]}
      results={[
        { value: '8', label: 'Интервью проведено' },
        { value: '3 из 4', label: 'Подтвержденных гипотез' },
      ]}
    />

    <CaseSection preTitle="Контекст и задача" title="AI Gateway — веб-приложение, которое помогает внутренним разработчикам ИИ-агентов отслеживать статус вывода ИИ-агента">
      Нужно было понять, с какими проблемами команды сталкиваются при выкатке решений в продакшн, насколько понятна существующая документация, и стоит ли перерабатывать её в формат интерфейса личного кабинета. Результат должен был помочь команде принять решение — дорабатывать документацию или проектировать MVP интерфейса взамен неё
    </CaseSection>

    <div class="grouped-section">
      <CaseSection preTitle="Процесс" title="Подготовил гайд и провёл 8 глубинных интервью в формате часовых онлайн-встреч">
        Опросил тех, кто уже прошёл процесс выкатки ИИ-агента в продакшн, и тех, кому это только предстоит, но кто знаком с документацией
      </CaseSection>

      <ImageBlock image={interviewQuestions} caption="Вопросы для интервью" />
    </div>

    <div class="grouped-section">
      <CaseSection preTitle="Инсайты" title="Все респонденты сходились в одном: документация не проводит по процессу пошагово">
        <p>Самый частый вопрос новых команд — «с чего начать?». Один из участников описал первое знакомство с инструкцией коротко: реакция была «непонятно», даже после прочтения quick start. Другой отметил, что вместо таблицы шагов хотел бы видеть понятный воркфлоу, по которому можно просто идти</p>
        <p>Респонденты почти единогласно говорили, что в сложных случаях идут не в документацию, а к коллегам, и что статус своего агента чаще всего отслеживают вручную, через переписку или личные договорённости, а не через какой-либо системный источник правды</p>
      </CaseSection>

      <div class="hypotheses">
        {hypotheses.map((h) => (
          <StatusCard status={h.status}>{h.text}</StatusCard>
        ))}
      </div>
    </div>

    <div class="grouped-section">
      <CaseSection preTitle="Результат" title="По итогам исследования сформулировал рекомендации по каждой проблемной зоне">
        Провёл 8 интервью с продукт-оунерами и аналитиками, которые ведут процесс выкатки ИИ-агентов, и подтвердил 3 из 4 гипотез. Собрал набор конкретных рекомендаций по документации, интерфейсу и процессу и презентовал результаты команде
      </CaseSection>

      <ImageBlock image={resultSummary} />
    </div>
  </div>
</CaseLayout>

<style>
  .page {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 100px;
    width: 100%;
    padding-block: 0 96px;
  }

  .grouped-section {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 44px;
    width: 100%;
  }

  .hypotheses {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    width: 100%;
  }
</style>
