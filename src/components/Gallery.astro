---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  caption?: string;
  framed?: boolean;
  height?: number;
}

const { images, caption, framed = false, height = 600 } = Astro.props;
const displayHeight = framed ? height - 32 : height;

function imageSize(image: ImageMetadata) {
  const h = Math.min(displayHeight * 2, image.height);
  const w = Math.round(h * (image.width / image.height));
  return { width: w, height: h };
}
---

<figure class="gallery">
  <div class="row" style={`height:${height}px`}>
    {images.map((image) =>
      framed ? (
        <div class="frame">
          <Image src={image} alt="" {...imageSize(image)} quality={90} class="image" />
        </div>
      ) : (
        <Image src={image} alt="" {...imageSize(image)} quality={90} class="image" />
      )
    )}
  </div>
  {caption && <figcaption class="text-tag caption" data-i18n-scope>{caption}</figcaption>}
</figure>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .row {
    display: flex;
    gap: 24px;
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .row::-webkit-scrollbar {
    display: none;
  }

  .image {
    flex-shrink: 0;
    height: 100%;
    width: auto;
    max-width: none;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .frame {
    flex-shrink: 0;
    display: flex;
    height: 100%;
    padding: 16px;
    box-sizing: border-box;
    border-radius: var(--radius-xl);
    background: var(--color-black-3);
  }
  .frame .image {
    border-radius: var(--radius-sm);
  }

  .caption {
    color: var(--color-blue-dusk);
    text-align: center;
  }
</style>
