---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  caption?: string;
  height?: number;
}

const { images, caption, height = 600 } = Astro.props;

function imageSize(image: ImageMetadata) {
  const h = Math.min(height * 2, image.height);
  const w = Math.round(h * (image.width / image.height));
  return { width: w, height: h };
}
---

<figure class="gallery">
  <div class="row" style={`height:${height}px`}>
    {images.map((image) => (
      <Image src={image} alt="" {...imageSize(image)} quality={90} class="image" />
    ))}
  </div>
  {caption && <figcaption class="text-tag caption" data-i18n-scope>{caption}</figcaption>}
</figure>

<style>
  .gallery {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .row {
    display: flex;
    gap: 24px;
    width: 100%;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .row::-webkit-scrollbar {
    display: none;
  }

  .image {
    flex-shrink: 0;
    height: 100%;
    width: auto;
    max-width: none;
    border-radius: var(--radius-lg);
    object-fit: cover;
  }

  .caption {
    color: var(--color-blue-dusk);
    text-align: center;
  }
</style>
