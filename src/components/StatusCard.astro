---
import Icon from './Icon.astro';

interface Props {
  /* confirmed — зелёная галочка, rejected — серый крест */
  status?: 'confirmed' | 'rejected';
}

const { status = 'confirmed' } = Astro.props;
---

<div class="status-card">
  <Icon name={status === 'confirmed' ? 'check-circle' : 'x-circle'} class="status-icon" />
  <p class="text-label text" data-i18n-scope><slot /></p>
</div>

<style>
  .status-card {
    display: flex;
    flex: 1 0 0;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    padding: 24px;
    border-radius: var(--radius-xl);
    background: var(--color-white);
    border: 1px solid var(--color-black-6);
    overflow: clip;
  }

  .status-icon {
    width: 32px;
    height: 32px;
  }

  .text {
    color: var(--color-black);
  }
</style>
