---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  logo: ImageMetadata;
  title: string;
  org: string;
  year: string;
}

const { logo, title, org, year } = Astro.props;
---

<div class="education-item">
  <Image src={logo} alt="" width={240} height={240} quality={90} fit="contain" class="logo" />
  <div class="description">
    <p class="text-label" data-i18n-scope>{title}</p>
    <p class="text-body org">{org}</p>
    <p class="text-body year">{year}</p>
  </div>
</div>

<style>
  .education-item {
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .logo {
    width: 80px;
    height: 80px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    flex-shrink: 0;
  }

  .description {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 4px;
  }

  .org,
  .year {
    color: var(--color-zinc-dust);
  }
</style>
