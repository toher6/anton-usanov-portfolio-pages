---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  caption?: string;
  framed?: boolean;
}

const { image, caption, framed = true } = Astro.props;
---

<figure class="image-block">
  {framed ? (
    <div class="frame">
      <Image src={image} alt="" width={Math.min(2336, image.width)} quality={90} class="image" />
    </div>
  ) : (
    <Image src={image} alt="" width={Math.min(2400, image.width)} quality={90} class="image image--flush" />
  )}
  {caption && <figcaption class="text-tag caption" data-i18n-scope>{caption}</figcaption>}
</figure>

<style>
  .image-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .frame {
    display: flex;
    padding: 16px;
    border-radius: var(--radius-xl);
    background: var(--color-black-3);
    width: 100%;
  }

  .image {
    width: 100%;
    height: auto;
  }

  .frame .image {
    border-radius: var(--radius-sm);
  }

  .image--flush {
    border-radius: var(--radius-lg);
  }

  .caption {
    color: var(--color-blue-dusk);
    text-align: center;
  }
</style>
