---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import StatusTag from './StatusTag.astro';
import profilePhoto from '../assets/images/profile/profile-photo.jpg';
import { CONTACTS } from '../data/contacts';
---

<section class="hero">
  <div class="dots" aria-hidden="true"></div>
  <div class="photo-frame">
    <Image src={profilePhoto} alt="Антон Усанов" width={702} height={702} quality={90} class="photo" />
  </div>
  <div class="description">
    <StatusTag data-i18n="hero.status">Открыт к предложениям</StatusTag>
    <div class="bio">
      <p class="text-h1" data-i18n="hero.name">Антон Усанов</p>
      <p class="text-body subtitle" data-i18n="hero.subtitle">
        Продуктовый дизайнер с опытом работы над продуктами в сферах AI, девелопмента, логистики, web3
      </p>
    </div>
    <div class="buttons">
      <Button variant="primary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
        Telegram
      </Button>
      <Button variant="primary" icon="email" iconPosition="left" copy={CONTACTS.email}>
        Email
      </Button>
      <Button variant="primary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
        CV
      </Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 44px;
    padding: 92px 200px 0;
  }

  .dots {
    position: absolute;
    inset: -40px -88px;
    background-image:
      radial-gradient(ellipse 96.5% 100% at 50% 50%, transparent 72%, var(--color-dr-white) 100%),
      radial-gradient(var(--color-black-24) 1px, transparent 1px);
    background-size: 100% 100%, 16px 16px;
    pointer-events: none;
  }

  .photo-frame {
    position: relative;
    width: 192px;
    height: 192px;
    border-radius: 22px;
    overflow: hidden;
  }

  .photo {
    position: absolute;
    left: -9.9%;
    top: -2.6%;
    width: 121.87%;
    height: 121.87%;
    max-width: none;
  }

  .description {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: 100%;
  }

  .bio {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .subtitle {
    color: var(--color-zinc-dust);
    max-width: 620px;
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>
