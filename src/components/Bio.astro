---
import { Image } from 'astro:assets';
import Button from './Button.astro';
import StatusTag from './StatusTag.astro';
import profilePhoto from '../assets/images/profile/profile-photo.jpg';
import { CONTACTS } from '../data/contacts';
---

<section class="hero">
  <svg class="dots" aria-hidden="true" focusable="false">
    <defs>
      <pattern id="hero-dot-grid" width="16" height="16" patternUnits="userSpaceOnUse">
        <circle cx="1" cy="1" r="0.9554" fill="var(--color-black-24)" />
      </pattern>
      <radialGradient
        id="hero-dot-fade"
        gradientUnits="objectBoundingBox"
        cx="0.5"
        cy="0.5"
        r="0.5"
        gradientTransform="translate(0.5 0.5) scale(0.965 1) translate(-0.5 -0.5)"
      >
        <stop offset="72%" stop-color="#fff" />
        <stop offset="100%" stop-color="#000" />
      </radialGradient>
      <mask id="hero-dot-mask" maskContentUnits="objectBoundingBox">
        <rect width="1" height="1" fill="url(#hero-dot-fade)" />
      </mask>
    </defs>
    <rect width="100%" height="100%" fill="url(#hero-dot-grid)" mask="url(#hero-dot-mask)" />
  </svg>
  <div class="photo-frame">
    <Image src={profilePhoto} alt="Антон Усанов" width={702} height={702} quality={90} class="photo" />
  </div>
  <div class="description">
    <StatusTag data-i18n="hero.status">Открыт к предложениям</StatusTag>
    <div class="bio">
      <p class="text-h1" data-i18n="hero.name">Антон Усанов</p>
      <p class="text-body subtitle" data-i18n="hero.subtitle">
        Продуктовый дизайнер с опытом работы над продуктами в сферах AI, девелопмента, логистики, web3
      </p>
    </div>
    <div class="buttons">
      <Button variant="primary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
        Telegram
      </Button>
      <Button variant="primary" icon="email" iconPosition="left" copy={CONTACTS.email}>
        Email
      </Button>
      <Button variant="primary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
        CV
      </Button>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 44px;
    padding: 92px 200px 0;
  }

  .dots {
    position: absolute;
    top: -40px;
    left: -88px;
    width: calc(100% + 176px);
    height: calc(100% + 80px);
    max-width: none;
    pointer-events: none;
  }

  .photo-frame {
    position: relative;
    width: 192px;
    height: 192px;
    border: 6px solid var(--color-white);
    border-radius: 24px;
    overflow: hidden;
    transform: rotate(-3deg);
    box-shadow:
      0px 1px 1px -0.5px var(--color-black-3),
      0px 3px 3px -1.5px var(--color-black-3),
      0px 20px 20px -12px var(--color-black-3);
  }

  .photo {
    position: absolute;
    left: -10.03%;
    top: -0.13%;
    width: 121.87%;
    height: 121.87%;
    max-width: none;
  }

  .description {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    width: 100%;
  }

  .bio {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .subtitle {
    color: var(--color-zinc-dust);
    max-width: 620px;
  }

  .buttons {
    display: flex;
    align-items: center;
    gap: 12px;
  }
</style>
