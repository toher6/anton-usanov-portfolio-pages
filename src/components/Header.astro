---
import Button from './Button.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import auLogo from '../assets/images/logos/au-logo.svg?raw';
import { CONTACTS } from '../data/contacts';

interface Props {
  /* На страницах кейсов шапка видна сразу и уезжает вместе с контентом,
     на главной — проявляется после hero-блока и залипает сверху */
  variant?: 'reveal' | 'static';
}

const { variant = 'reveal' } = Astro.props;
---

<header class:list={['header', variant === 'static' && 'header--static header--pinned']}>
  <div class="header__bar">
    <a href="/" class="logo" aria-label="На главную" set:html={auLogo} />
    <nav class="header__links">
      <Button variant="tertiary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
        Telegram
      </Button>
      <Button variant="tertiary" icon="email" iconPosition="left" copy={CONTACTS.email}>
        Email
      </Button>
      <Button variant="tertiary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
        CV
      </Button>
    </nav>
    <LanguageSwitch />
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding-top: 16px;
  }

  .header--static {
    position: static;
  }

  .header__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
    padding-inline: 16px;
    border-radius: var(--radius-lg);
    background: var(--color-header-bg);
    border: 1px solid var(--color-black-6);
    box-shadow: var(--shadow-elevation);
    transition: background-color 250ms ease, border-color 250ms ease, box-shadow 250ms ease;
  }

  /*
    Пока hero-block в зоне видимости, шапка «пустая» — видно только
    переключатель языка (он остаётся на своём месте), а подложка, логотип
    и навигация скрыты. После прокрутки за hero-block шапка проявляется.
  */
  .header:not(.header--pinned) .header__bar {
    background: transparent;
    border-color: transparent;
    box-shadow: none;
  }

  .header:not(.header--pinned) .logo,
  .header:not(.header--pinned) .header__links {
    opacity: 0;
    pointer-events: none;
  }

  .logo {
    display: block;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    /* Скругление задаём тут: одинаковый clipPath id в нескольких инлайн-копиях
       SVG (header + футеры) ломает clip-path внутри самой картинки */
    border-radius: 8px;
    overflow: hidden;
    transition: opacity 250ms ease;
  }
  .logo :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .header__links {
    display: flex;
    align-items: center;
    gap: 24px;
    transition: opacity 250ms ease;
  }

  /* Мобильная вёрстка: хедера нет — переключатель языка живёт в hero-блоке */
  @media (max-width: 575.98px) {
    .header {
      display: none;
    }
  }
</style>

<script>
  function initHeaderReveal() {
    const header = document.querySelector<HTMLElement>('.header');
    if (!header || header.dataset.revealWired) return;
    header.dataset.revealWired = 'true';

    // Статичный вариант (страницы кейсов) виден всегда — наблюдатель не нужен
    if (header.classList.contains('header--static')) return;

    const hero = document.querySelector('.hero');
    // Нет hero-block (например, страница 404) — шапка всегда видима
    if (!hero) {
      header.classList.add('header--pinned');
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          header.classList.toggle('header--pinned', !entry.isIntersecting);
        }
      },
      // Верхняя граница сдвинута на высоту шапки (16px отступ + 68px бар),
      // чтобы шапка проявлялась, когда hero уходит под неё
      { rootMargin: '-84px 0px 0px 0px' },
    );
    observer.observe(hero);
  }

  initHeaderReveal();
  document.addEventListener('astro:page-load', initHeaderReveal);
</script>
