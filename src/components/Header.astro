---
import Button from './Button.astro';
import LanguageSwitch from './LanguageSwitch.astro';
import auLogo from '../assets/images/logos/au-logo.svg?raw';
import { CONTACTS } from '../data/contacts';
---

<header class="header">
  <div class="header__overlay"></div>
  <div class="header__bar">
    <a href="/" class="logo" aria-label="На главную" set:html={auLogo} />
    <nav class="header__links">
      <Button variant="tertiary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
        Telegram
      </Button>
      <Button variant="tertiary" icon="email" iconPosition="left" copy={CONTACTS.email}>
        Email
      </Button>
      <Button variant="tertiary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
        CV
      </Button>
    </nav>
    <LanguageSwitch />
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 50;
    height: 84px;
  }

  .header__overlay {
    position: absolute;
    inset: 0;
    background: var(--color-header-overlay);
    backdrop-filter: blur(2px);
    border-radius: 0 0 var(--radius-lg) var(--radius-lg);
  }

  .header__bar {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 12px 16px;
    border-radius: var(--radius-lg);
    background: var(--color-header-bg);
    border: 1px solid var(--color-black-6);
    box-shadow: var(--shadow-elevation);
  }

  .logo {
    display: block;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }
  .logo :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .header__links {
    display: flex;
    align-items: center;
    gap: 24px;
  }
</style>
