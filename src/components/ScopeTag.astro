---
interface Props {
  class?: string;
}
const { class: className } = Astro.props;
---

<div class:list={['scope-tag', className]}>
  <p class="text-tag"><slot /></p>
</div>

<style>
  .scope-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 12px;
    border-radius: var(--radius-pill);
    background: var(--color-white);
    border: 1px solid var(--color-black-6);
    box-shadow: var(--shadow-tag);
    color: var(--color-blue-dusk);
  }
</style>
