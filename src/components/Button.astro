---
import Icon from './Icon.astro';

interface Props {
  variant?: 'primary' | 'secondary' | 'tertiary';
  href?: string;
  copy?: string;
  icon?: 'telegram' | 'email' | 'cv' | 'arrow-up-right' | 'arrow-left-circle';
  iconPosition?: 'left' | 'right';
  class?: string;
  target?: string;
  rel?: string;
}

const {
  variant = 'primary',
  href,
  copy,
  icon,
  iconPosition = 'right',
  class: className,
  target,
  rel,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['button', `button--${variant}`, className]}
  href={href}
  target={target}
  rel={rel}
  type={Tag === 'button' ? 'button' : undefined}
  data-copy={copy}
  data-interactive
>
  {icon && iconPosition === 'left' && <Icon name={icon} />}
  <span class="text-button" data-i18n-scope><slot /></span>
  {icon && iconPosition === 'right' && <Icon name={icon} />}
</Tag>

<style>
  .button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border-radius: var(--radius-md);
    white-space: nowrap;
    cursor: pointer;
    transition: background-color 150ms ease, color 150ms ease, border-color 150ms ease, transform 150ms ease;
  }
  .button:hover {
    transform: translateY(-5px);
  }

  .button--primary {
    padding: 10px 16px;
    background-image: linear-gradient(180deg, rgba(255, 255, 255, 0.2) 20%, rgba(255, 255, 255, 0) 100%),
      linear-gradient(90deg, var(--color-black) 0%, var(--color-black) 100%);
    color: var(--color-white);
  }
  .button--primary:hover {
    background-image: none;
    background-color: var(--color-black);
  }
  .button--primary:active {
    outline: 2px solid var(--color-zinc-dust);
    outline-offset: -2px;
  }

  .button--secondary {
    padding: 10px;
    background: var(--color-black-3);
    border: 1px solid var(--color-black-6);
    color: var(--color-black);
    justify-content: center;
  }
  .button--secondary:hover,
  .button--secondary:active {
    background: var(--color-black-6);
  }

  .button--tertiary {
    height: 40px;
    padding: 10px 12px;
    background: transparent;
    color: var(--color-zinc-dust);
  }
  .button--tertiary:hover {
    color: var(--color-black);
  }
  .button--tertiary:active {
    color: var(--color-zinc-dust);
  }
</style>
