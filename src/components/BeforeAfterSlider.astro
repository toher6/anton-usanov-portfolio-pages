---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Icon from './Icon.astro';

interface Props {
  before: ImageMetadata;
  after: ImageMetadata;
  beforeLabel: string;
  afterLabel: string;
  caption?: string;
}

const { before, after, beforeLabel, afterLabel, caption } = Astro.props;
const uid = Math.random().toString(36).slice(2, 9);
---

<figure class="slider-block">
  <div class="slider" data-before-after-slider style={`--pos: 50%`}>
    <Image src={after} alt="" width={1168} class="layer layer--after" />
    <Image src={before} alt="" width={1168} class="layer layer--before" />
    <span class="tag tag--left" data-i18n-scope>{beforeLabel}</span>
    <span class="tag tag--right" data-i18n-scope>{afterLabel}</span>
    <div class="handle" aria-hidden="true">
      <Icon name="arrow-up-right" class="handle-icon" />
    </div>
    <input
      type="range"
      min="0"
      max="100"
      value="50"
      class="range"
      aria-label={`${beforeLabel} / ${afterLabel}`}
      id={`slider-${uid}`}
    />
  </div>
  {caption && <figcaption class="text-tag caption" data-i18n-scope>{caption}</figcaption>}
</figure>

<style>
  .slider-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .slider {
    position: relative;
    width: 100%;
    border-radius: var(--radius-xl);
    overflow: hidden;
    user-select: none;
  }

  .layer {
    display: block;
    width: 100%;
    height: auto;
  }

  .layer--after {
    position: relative;
  }

  .layer--before {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    clip-path: inset(0 calc(100% - var(--pos)) 0 0);
  }

  .tag {
    position: absolute;
    top: 32px;
    padding: 8px 12px;
    border-radius: var(--radius-pill);
    background: var(--color-black-64);
    color: var(--color-white);
    font-family: var(--font-body);
    font-size: var(--text-tag-size);
    line-height: var(--text-tag-line);
    font-weight: var(--text-tag-weight);
    pointer-events: none;
  }

  .tag--left {
    left: 32px;
  }

  .tag--right {
    right: 32px;
  }

  .handle {
    position: absolute;
    top: 50%;
    left: var(--pos);
    transform: translate(-50%, -50%);
    width: 40px;
    height: 40px;
    border-radius: var(--radius-md);
    background: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
  }

  .handle-icon {
    width: 20px;
    height: 20px;
    transform: rotate(45deg);
  }

  .range {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    margin: 0;
    opacity: 0;
    cursor: ew-resize;
    appearance: none;
  }

  .caption {
    color: var(--color-blue-dusk);
    text-align: center;
  }
</style>

<script>
  function initSliders(root: ParentNode = document) {
    root.querySelectorAll<HTMLElement>('[data-before-after-slider]').forEach((slider) => {
      if (slider.dataset.wired) return;
      slider.dataset.wired = 'true';
      const range = slider.querySelector<HTMLInputElement>('.range');
      range?.addEventListener('input', () => {
        slider.style.setProperty('--pos', `${range.value}%`);
      });
    });
  }
  initSliders();
  document.addEventListener('astro:page-load', () => initSliders());
</script>
