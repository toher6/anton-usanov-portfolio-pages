---
import Button from './Button.astro';
import auLogo from '../assets/images/logos/au-logo.svg?raw';
import { CONTACTS } from '../data/contacts';
import { SITE } from '../data/site';
---

<footer class="footer footer--desktop">
  <div class="logo-frame">
    <a href="/" class="logo" aria-label="На главную" set:html={auLogo} />
  </div>
  <nav class="footer__links">
    <Button variant="tertiary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
      Telegram
    </Button>
    <Button variant="tertiary" icon="email" iconPosition="left" copy={CONTACTS.email}>
      Email
    </Button>
    <Button variant="tertiary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
      CV
    </Button>
  </nav>
  <p class="text-tag updated" data-i18n data-i18n-en={SITE.updatedAtEn}>{SITE.updatedAt}</p>
</footer>

<footer class="footer-mobile">
  <a href="/" class="logo" aria-label="На главную" set:html={auLogo} />
  <nav class="footer-mobile__links">
    <Button variant="tertiary" icon="telegram" iconPosition="left" href={CONTACTS.telegram} target="_blank" rel="noreferrer">
      Telegram
    </Button>
    <Button variant="tertiary" icon="email" iconPosition="left" copy={CONTACTS.email}>
      Email
    </Button>
    <Button variant="tertiary" icon="cv" iconPosition="left" href={CONTACTS.cv} target="_blank" rel="noreferrer">
      CV
    </Button>
  </nav>
  <p class="text-tag updated" data-i18n data-i18n-en={SITE.updatedAtEn}>{SITE.updatedAt}</p>
</footer>

<style>
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 220px;
    padding-bottom: 40px;
    width: 100%;
  }

  .logo-frame {
    display: flex;
    align-items: center;
    width: 156px;
    flex-shrink: 0;
  }

  .logo {
    display: block;
    width: 40px;
    height: 40px;
    flex-shrink: 0;
  }
  .logo :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
  }

  .footer__links {
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .updated {
    width: 156px;
    text-align: right;
    font-weight: 400;
    color: var(--color-zinc-dust);
  }

  /* Мобильный футер — столбец: логотип, три ссылки по ширине, дата по центру */
  .footer-mobile {
    display: none;
  }

  @media (max-width: 575.98px) {
    .footer--desktop {
      display: none;
    }

    .footer-mobile {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 20px;
      margin-top: 92px;
      padding-bottom: 44px;
      width: 100%;
    }

    .footer-mobile__links {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
    }

    .footer-mobile .updated {
      width: auto;
      text-align: center;
    }
  }
</style>
