---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  images: ImageMetadata[];
  caption?: string;
}

const { images, caption } = Astro.props;
---

<figure class="image-grid">
  <div class="row">
    {images.map((image) => (
      <Image src={image} alt="" width={800} class="image" />
    ))}
  </div>
  {caption && <figcaption class="text-tag caption" data-i18n-scope>{caption}</figcaption>}
</figure>

<style>
  .image-grid {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    width: 100%;
  }

  .row {
    display: flex;
    gap: 24px;
    align-items: stretch;
    width: 100%;
  }

  .image {
    flex: 1 1 0;
    min-width: 0;
    width: 100%;
    height: 600px;
    object-fit: cover;
    border-radius: var(--radius-lg);
  }

  .caption {
    color: var(--color-blue-dusk);
    text-align: center;
  }
</style>
