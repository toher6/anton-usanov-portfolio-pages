---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Button from './Button.astro';

interface Props {
  title: string;
  companyLogo: ImageMetadata;
  companyName: string;
  description: string;
  href: string;
  image: ImageMetadata;
}

const { title, companyLogo, companyName, description, href, image } = Astro.props;
---

<article class="card">
  <div class="image-frame">
    <Image src={image} alt="" width={1662} height={1260} format="webp" class="image" />
  </div>
  <div class="right">
    <div class="description">
      <div class="title">
        <p class="text-h2" data-i18n-scope>{title}</p>
        <div class="row">
          <p class="text-h2" data-i18n="common.for">для</p>
          <div class="product-name">
            <Image src={companyLogo} alt="" width={96} height={96} quality={90} fit="contain" class="company-logo" />
            <p class="text-h2" data-i18n-scope>{companyName}</p>
          </div>
        </div>
      </div>
      <p class="text-body summary" data-i18n-scope>{description}</p>
    </div>
    <Button variant="primary" href={href} icon="arrow-up-right">Смотреть кейс</Button>
  </div>
</article>

<style>
  .card {
    display: flex;
    align-items: center;
    gap: 56px;
    border-radius: var(--radius-2xl);
    background: var(--color-black-3);
    overflow: clip;
    width: 100%;
    height: 420px;
  }

  .image-frame {
    width: 554px;
    height: 420px;
    border-radius: var(--radius-2xl);
    overflow: clip;
    flex-shrink: 0;
  }

  .image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }

  .right {
    display: flex;
    flex: 1 0 0;
    flex-direction: column;
    align-items: flex-start;
    justify-content: space-between;
    height: 348px;
    min-width: 0;
    padding-right: 36px;
  }

  .description {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    width: 100%;
  }

  .title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .product-name {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .company-logo {
    width: 32px;
    height: 32px;
    border-radius: 4px;
  }

  .summary {
    color: var(--color-zinc-dust);
  }
</style>
