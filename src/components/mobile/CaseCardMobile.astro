---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import ScopeTag from '../ScopeTag.astro';
import Button from '../Button.astro';

interface Props {
  tags?: string[];
  title: string;
  companyLogo: ImageMetadata;
  companyName: string;
  description: string;
  href: string;
  image: ImageMetadata;
  imagePosition?: string;
}

const { tags, title, companyLogo, companyName, description, href, image, imagePosition = 'center' } = Astro.props;

// Обложку кадрируем до 4:3 на этапе сборки (sharp), с нужной позицией кропа,
// в 3× от размера показа (368×276) — чтобы было резко на экранах с DPR 3
const cropWidth = 1104;
const cropHeight = 828;
---

<article class="case-card-mobile">
  <div class="head">
    <div class="description">
      {tags && tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => <ScopeTag>{tag}</ScopeTag>)}
        </div>
      )}
      <div class="case-title">
        <p class="text-h2" data-i18n-scope>{title}</p>
        <div class="row">
          <p class="text-h2" data-i18n="common.for">для</p>
          <div class="product-name">
            <Image src={companyLogo} alt="" width={72} height={72} quality={90} fit="contain" class="company-logo" />
            <p class="text-h2" data-i18n-scope>{companyName}</p>
          </div>
        </div>
      </div>
      <p class="text-body summary" data-i18n-scope>{description}</p>
    </div>
    <Button variant="primary" href={href} icon="arrow-up-right">Смотреть кейс</Button>
  </div>
  <div class="image-container">
    <Image src={image} alt="" width={cropWidth} height={cropHeight} fit="cover" position={imagePosition} quality={100} format="avif" class="image" />
  </div>
</article>

<style>
  .case-card-mobile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 36px;
    padding-top: 20px;
    border-radius: var(--radius-lg);
    background: var(--color-black-3);
    overflow: clip;
    width: 100%;
  }

  .head {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
    padding-inline: 20px;
    width: 100%;
  }

  .description {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
    width: 100%;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-bottom: 4px;
  }

  .case-title {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .row {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .product-name {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .company-logo {
    width: 24px;
    height: 24px;
    border-radius: 6px;
  }

  .summary {
    color: var(--color-zinc-dust);
  }

  .image-container {
    width: 100%;
    aspect-ratio: 368 / 276;
    border-radius: var(--radius-lg);
    overflow: clip;
  }

  .image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    user-select: none;
  }
</style>
