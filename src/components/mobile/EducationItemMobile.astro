---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  logo: ImageMetadata;
  title: string;
  org: string;
  year: string;
}

const { logo, title, org, year } = Astro.props;
---

<div class="education-item-mobile">
  <Image src={logo} alt="" width={168} height={168} quality={90} fit="contain" class="logo" />
  <div class="description">
    <p class="text-label" data-i18n-scope>{title}</p>
    <p class="text-body org" data-i18n-scope>{org}</p>
    <p class="text-body year">{year}</p>
  </div>
</div>

<style>
  .education-item-mobile {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 20px;
    width: 100%;
  }

  .logo {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    object-fit: cover;
    flex-shrink: 0;
  }

  .description {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    width: 100%;
  }

  .org,
  .year {
    color: var(--color-zinc-dust);
  }
</style>
